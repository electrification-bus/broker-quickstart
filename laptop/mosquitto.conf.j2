# Rendered by laptop/broker.py for the Mac laptop deployment (profile: {{ profile }}).
# Host-native, user-writable paths, no root. Do not hand-edit the rendered copy;
# change the template and re-run the broker. Profile semantics: docs/security-profiles.md.
{% if per_listener %}
# Listeners differ on access rules (ACL vs none), so settings are scoped per listener.
per_listener_settings true
{% endif %}
{% for l in listeners %}
# ---------------------------------------------------------------------------
{% if not l.tls %}
{% if l.bind %}
# Plaintext debug tap on {{ l.port }} ({{ l.bind }} only, NOT advertised, no ACL).
{% elif l.acl %}
# Plaintext anonymous READ window on {{ l.port }} (advertised _mqtt._tcp).
# Read-only by ACL: anonymous clients can read lifecycle topics, nothing else.
{% else %}
# OPEN plaintext listener on {{ l.port }}, anonymous read+write (all interfaces).
# DO NOT expose this to an untrusted network.
{% endif %}
{% else %}
# mTLS listener on {{ l.port }} (advertised _secure-mqtt._tcp). A client cert is
# REQUIRED; the cert CN is the username. Devices own their ebus/5/<user>/# subtree.
{% endif %}
# ---------------------------------------------------------------------------
listener {{ l.port }}{% if l.bind %} {{ l.bind }}{% endif %}

protocol mqtt
{% if l.tls %}
cafile {{ ca_cert }}
certfile {{ server_cert }}
keyfile {{ server_key }}
tls_version tlsv1.2
{% endif %}
{% if l.require_certificate %}
require_certificate true
{% endif %}
{% if l.use_identity_as_username %}
use_identity_as_username true
{% endif %}
allow_anonymous true
{% if l.acl %}
acl_file {{ acl_file }}
{% endif %}
{% endfor %}
# ---------------------------------------------------------------------------
# Runtime / persistence (all under the user-writable state dir)
# ---------------------------------------------------------------------------
persistence true
persistence_location {{ state_dir }}/
pid_file {{ state_dir }}/mosquitto.pid

log_dest stdout
log_type error
log_type warning
log_type notice
log_type information
{% if bridge %}

# ---------------------------------------------------------------------------
# Bridge to a remote broker at {{ bridge.host }}:{{ bridge.port }} ({{ bridge.direction }}).
# Sits behind the local broker; the local listeners and mDNS advertisement are
# unchanged. Must come after the global settings above.
# ---------------------------------------------------------------------------
connection {{ bridge.name }}
address {{ bridge.host }}:{{ bridge.port }}
topic {{ bridge.topic }} {{ bridge.direction }} {{ bridge.qos }}
{% if bridge.clientid %}
remote_clientid {{ bridge.clientid }}
{% endif %}
{% if bridge.username %}
remote_username {{ bridge.username }}
remote_password {{ bridge.password }}
{% endif %}
{% if bridge.protocol_version %}
bridge_protocol_version {{ bridge.protocol_version }}
{% endif %}
{% if bridge.cafile %}
bridge_cafile {{ bridge.cafile }}
{% if bridge.certfile %}
bridge_certfile {{ bridge.certfile }}
bridge_keyfile {{ bridge.keyfile }}
{% endif %}
bridge_insecure {{ 'true' if bridge.insecure else 'false' }}
{% endif %}
cleansession true
notifications false
try_private true
start_type automatic
restart_timeout 5
{% endif %}
